{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "k_and_b",
  "version": "1.2.0",
  "identifier": "com.kandb.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "k_and_b",
        "decorations": true,
        "transparent": false,
        "width": 1300,
        "height": 1100,
        "minWidth": 1300,
        "minHeight": 1100
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}